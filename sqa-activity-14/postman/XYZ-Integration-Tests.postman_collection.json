{
  "info": {
    "_postman_id": "fe50e71e-8534-422d-94f9-951f417caa7b",
    "name": "XYZ Integration Tests",
    "description": "Coleccion para pruebas de integracion del modulo User Service en Proyecto XYZ.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "username",
      "value": "integration.tester"
    },
    {
      "key": "password",
      "value": "StrongPass!123"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "userEmail",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "00 - Authentication",
      "item": [
        {
          "name": "Login - Get Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estado 200 en autenticacion', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Respuesta contiene accessToken', function () {",
                  "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.collectionVariables.set('token', json.accessToken);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - User Lifecycle",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ana\",\n  \"lastName\": \"Ramirez\",\n  \"email\": \"ana.ramirez+{{$timestamp}}@xyz.local\",\n  \"phone\": \"8095551111\",\n  \"status\": \"active\",\n  \"metadata\": {\n    \"channel\": \"web\",\n    \"locale\": \"es-DO\"\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estado 201 al crear usuario', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Payload de creacion contiene id y email', function () {",
                  "  pm.expect(json.id).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.email).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.collectionVariables.set('userId', json.id);",
                  "pm.collectionVariables.set('userEmail', json.email);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estado 200 al consultar usuario', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Email consultado coincide con usuario creado', function () {",
                  "  pm.expect(json.email).to.eql(pm.collectionVariables.get('userEmail'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ana Actualizada\",\n  \"status\": \"suspended\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estado 200 en actualizacion', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Estado funcional actualizado a suspended', function () {",
                  "  pm.expect(json.status).to.eql('suspended');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estado 204 al eliminar usuario', function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Deleted User - Not Found",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estado 404 despues de eliminar', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Negative and Resilience",
      "item": [
        {
          "name": "Create User - Invalid Payload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"\",\n  \"email\": \"correo-invalido\",\n  \"status\": \"unknown\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estado 400 para payload invalido', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Error funcional de validacion presente', function () {",
                  "  pm.expect(json.error.code).to.eql('VALIDATION_ERROR');",
                  "  pm.expect(json.error.message).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User - Dependency Timeout",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/simulate-crm-timeout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "simulate-crm-timeout"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estado 503 cuando dependencia falla', function () {",
                  "  pm.response.to.have.status(503);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Mensaje funcional de timeout de dependencia', function () {",
                  "  pm.expect(json.error.message).to.eql('CRM dependency timeout');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
